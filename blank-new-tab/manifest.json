{
  "manifest_version": 3,
  "name": "Blank New Tab",
  "version": "1.0.0",
  "description": "Replace new tabs with a clean, customizable blank page.",
  "permissions": ["storage", "bookmarks"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
